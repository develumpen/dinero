<% content_for :title, "Accounts" %>

<h1>Accounts</h1>

<%= link_to "New account", new_account_path %>

<div id="accounts" class="accounts-list">
  <% @accounts.each do |account| %>
    <div id="<%= dom_id account %>" class="account-in-list">
      <%= link_to account.name, account %>
      <p>
        <%= account.description %>
      </p>
    </div>
  <% end %>
</div>
