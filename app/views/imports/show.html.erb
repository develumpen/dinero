<div id="<%= dom_id @import %>">
  <h1><%= link_to @import.account.name, @import.account %></h1>

  <%= @import.file.filename %>

  <div class="import-meta">
    <%= button_to "Destroy this import", @import, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
  </div>

  <table>
    <thead>
      <tr>
        <% @csv_data.headers.each do |header| %>
          <th><%= header %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @csv_data.each do |row| %>
        <tr>
          <% @csv_data.headers.each do |header| %>
            <td><%= row[header] %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
